@using OpenAnima.Core.Artifacts
@using Markdig
@inject IArtifactStore ArtifactStore
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L

@if (_artifact != null)
{
    <section class="artifact-section" role="region" aria-label="@L["Artifact.SectionAria", FileName]">
        <label class="artifact-label">@L["Artifact.Title"]</label>
        <div class="artifact-block">
            <div class="artifact-header">
                <span class="mime-badge">@_artifact.MimeType</span>
                <span class="artifact-filename">@FileName</span>
                <span class="artifact-size">@FormatSize(_artifact.FileSizeBytes)</span>
            </div>
            <div class="artifact-content">
                @if (_artifact.MimeType == "text/markdown")
                {
                    <div class="markdown-body">@((MarkupString)_renderedHtml)</div>
                }
                else if (_artifact.MimeType == "application/json")
                {
                    <pre class="json-content">@_displayContent</pre>
                }
                else if (_artifact.MimeType == "text/html")
                {
                    <pre class="plain-text">@_displayContent</pre>
                }
                else
                {
                    <pre class="plain-text">@_displayContent</pre>
                }
            </div>
            @if (_isTruncated && !_isExpanded)
            {
                <button class="expand-btn" @onclick="LoadFullContent"
                        aria-label="@L["Artifact.ViewFullContentAria", FileName]">
                    @TruncationNotice
                </button>
            }
            else if (_isExpanded)
            {
                <button class="expand-btn" @onclick="CollapseContent"
                        aria-label="@L["Artifact.CollapseContentAria", FileName]">
                    @L["Common.Collapse"]
                </button>
            }
            @if (_loadError != null)
            {
                <div class="artifact-error">
                    <span>@L["Artifact.LoadError"]</span>
                    <button class="retry-btn" @onclick="LoadArtifact">@L["Common.Retry"]</button>
                </div>
            }
        </div>
        <div class="artifact-provenance">
            @L["Artifact.Provenance"]
            <a href="@($"/runs/{_artifact.RunId}#step-{_artifact.StepId}")"
               class="provenance-link"
               aria-label="@L["Artifact.ViewStepAria", _artifact.StepId]">
                @L["Common.Step"] @_artifact.StepId
            </a>
            &middot;
            <a href="@($"/runs/{_artifact.RunId}")"
               class="provenance-link"
               aria-label="@L["Artifact.ViewRunAria", _artifact.RunId]">
                @L["Common.Run"] @_artifact.RunId
            </a>
        </div>
    </section>
}

@code {
    [Parameter] public string? ArtifactRefId { get; set; }

    private ArtifactRecord? _artifact;
    private string? _fullContent;
    private string? _displayContent;
    private string _renderedHtml = string.Empty;
    private bool _isTruncated;
    private bool _isExpanded;
    private string? _loadError;

    private const int MaxPreviewLines = 200;
    private const int MaxPreviewBytes = 10 * 1024; // 10KB

    private string FileName => _artifact?.FilePath.Split('/').Last() ?? "";
    private string TruncationNotice => L["Artifact.PreviewNotice", _previewLineCount];
    private int _previewLineCount;

    protected override async Task OnParametersSetAsync()
    {
        if (ArtifactRefId != null)
            await LoadArtifact();
    }

    private async Task LoadArtifact()
    {
        _loadError = null;
        try
        {
            _artifact = await ArtifactStore.GetArtifactByIdAsync(ArtifactRefId!);
            if (_artifact == null) return;

            _fullContent = await ArtifactStore.ReadContentAsync(ArtifactRefId!);
            if (_fullContent == null) return;

            ApplyTruncation(_fullContent);
            RenderContent();
        }
        catch (Exception)
        {
            _loadError = "load_failed";
        }
    }

    private void ApplyTruncation(string content)
    {
        var lines = content.Split('\n');
        _previewLineCount = Math.Min(lines.Length, MaxPreviewLines);

        if (lines.Length > MaxPreviewLines || System.Text.Encoding.UTF8.GetByteCount(content) > MaxPreviewBytes)
        {
            _isTruncated = true;
            var truncatedLines = lines.Take(MaxPreviewLines);
            var truncated = string.Join('\n', truncatedLines);
            if (System.Text.Encoding.UTF8.GetByteCount(truncated) > MaxPreviewBytes)
            {
                truncated = truncated[..Math.Min(truncated.Length, MaxPreviewBytes)];
            }
            _displayContent = truncated;
        }
        else
        {
            _isTruncated = false;
            _displayContent = content;
        }
        _isExpanded = false;
    }

    private void RenderContent()
    {
        if (_artifact?.MimeType == "text/markdown" && _displayContent != null)
        {
            var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
            _renderedHtml = Markdown.ToHtml(_displayContent, pipeline);
        }
    }

    private async Task LoadFullContent()
    {
        if (_fullContent == null) return;
        _displayContent = _fullContent;
        _isExpanded = true;
        _isTruncated = false;
        RenderContent();
        await Task.CompletedTask;
    }

    private Task CollapseContent()
    {
        if (_fullContent != null)
        {
            ApplyTruncation(_fullContent);
            RenderContent();
        }
        return Task.CompletedTask;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
