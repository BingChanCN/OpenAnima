@inject IStringLocalizer<SharedResources> L
@inject LanguageService LangSvc
@implements IDisposable

@if (IsVisible)
{
    <div class="context-menu-backdrop" @onclick="HandleClose"></div>
    <div class="context-menu" style="left: @(X)px; top: @(Y)px;" @onclick:stopPropagation="true">
        @if (!IsEnabled)
        {
            <button class="context-menu-item" @onclick="HandleEnable">@L["Modules.Enable"]</button>
        }
        else
        {
            <button class="context-menu-item" @onclick="HandleDisable">@L["Modules.Disable"]</button>
        }
        <button class="context-menu-item" @onclick="HandleViewDetails">@L["Modules.ViewDetails"]</button>
        <button class="context-menu-item context-menu-item--danger" @onclick="HandleUninstall">@L["Modules.Uninstall"]</button>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public double X { get; set; }
    [Parameter] public double Y { get; set; }
    [Parameter] public string ModuleName { get; set; } = "";
    [Parameter] public bool IsEnabled { get; set; }
    [Parameter] public EventCallback OnEnable { get; set; }
    [Parameter] public EventCallback OnDisable { get; set; }
    [Parameter] public EventCallback OnUninstall { get; set; }
    [Parameter] public EventCallback OnViewDetails { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    protected override void OnInitialized()
    {
        LangSvc.LanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private async Task HandleEnable()
    {
        await OnClose.InvokeAsync();
        await OnEnable.InvokeAsync();
    }

    private async Task HandleDisable()
    {
        await OnClose.InvokeAsync();
        await OnDisable.InvokeAsync();
    }

    private async Task HandleViewDetails()
    {
        await OnClose.InvokeAsync();
        await OnViewDetails.InvokeAsync();
    }

    private async Task HandleUninstall()
    {
        await OnClose.InvokeAsync();
        await OnUninstall.InvokeAsync();
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }

    public void Dispose()
    {
        LangSvc.LanguageChanged -= OnLanguageChanged;
    }
}
