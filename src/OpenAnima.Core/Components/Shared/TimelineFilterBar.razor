@inject IStringLocalizer<SharedResources> L

<div class="filter-bar">
    <div class="filter-group">
        <label for="filter-module">@L["RunDetail.Filter.Module"]</label>
        <select id="filter-module" @onchange="HandleModuleChange">
            <option value="">@L["RunDetail.Filter.AllModules"]</option>
            @foreach (var m in ModuleNames)
            {
                <option value="@m" selected="@(m == SelectedModule)">@m</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label for="filter-status">@L["RunDetail.Filter.Status"]</label>
        <select id="filter-status" @onchange="HandleStatusChange">
            <option value="">@L["RunDetail.Filter.AllStatuses"]</option>
            @foreach (var s in Statuses)
            {
                <option value="@s" selected="@(s == SelectedStatus)">@s</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label for="filter-chain">@L["RunDetail.Filter.Chain"]</label>
        <select id="filter-chain" @onchange="HandleChainChange">
            <option value="">@L["RunDetail.Filter.AllChains"]</option>
            @foreach (var c in ChainIds)
            {
                <option value="@c" selected="@(c == SelectedChain)">@(c.Length > 8 ? c[..8] + "…" : c)</option>
            }
        </select>
    </div>
    @if (HasActiveFilters)
    {
        <button class="btn-clear-filters" @onclick="OnClearFilters">@L["RunDetail.Filter.ClearFilters"]</button>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<string> ModuleNames { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> Statuses { get; set; } = Array.Empty<string>();
    [Parameter] public IReadOnlyList<string> ChainIds { get; set; } = Array.Empty<string>();
    [Parameter] public string? SelectedModule { get; set; }
    [Parameter] public string? SelectedStatus { get; set; }
    [Parameter] public string? SelectedChain { get; set; }
    [Parameter] public EventCallback<string?> OnModuleFilterChanged { get; set; }
    [Parameter] public EventCallback<string?> OnStatusFilterChanged { get; set; }
    [Parameter] public EventCallback<string?> OnChainFilterChanged { get; set; }
    [Parameter] public EventCallback OnClearFilters { get; set; }
    [Parameter] public bool HasActiveFilters { get; set; }

    private async Task HandleModuleChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        await OnModuleFilterChanged.InvokeAsync(string.IsNullOrEmpty(val) ? null : val);
    }

    private async Task HandleStatusChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        await OnStatusFilterChanged.InvokeAsync(string.IsNullOrEmpty(val) ? null : val);
    }

    private async Task HandleChainChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        await OnChainFilterChanged.InvokeAsync(string.IsNullOrEmpty(val) ? null : val);
    }
}

<style>
    .filter-bar { display: flex; align-items: center; gap: 16px; padding: 8px 16px; background: var(--surface-dark); border: 1px solid var(--border-color); border-radius: 8px; flex-wrap: wrap; }
    .filter-group { display: flex; align-items: center; gap: 4px; }
    .filter-group label { font-size: 12px; color: var(--text-secondary); white-space: nowrap; }
    .filter-group select { background: var(--bg-primary); color: var(--text-primary); border: 1px solid var(--border-color); border-radius: 4px; padding: 4px 8px; font-size: 12px; min-width: 120px; }
    .filter-group select:focus { outline: 1px solid var(--accent-color); }
    .btn-clear-filters { background: transparent; color: var(--accent-color); border: 1px solid var(--accent-color); border-radius: 4px; padding: 4px 12px; font-size: 12px; cursor: pointer; margin-left: auto; }
    .btn-clear-filters:hover { background: rgba(108,140,255,0.12); }
</style>
