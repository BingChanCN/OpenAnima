@using OpenAnima.Contracts
@using OpenAnima.Core.Services
@using OpenAnima.Core.Anima
@implements IAsyncDisposable
@inject ChatBackgroundExecutionService _chatExecutionService
@inject ChatContextManager _contextManager
@inject IAnimaRuntimeManager _animaRuntimeManager
@inject IModuleContext _animaContext
@inject NavigationManager _navigation
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> L
@inject LanguageService LangSvc

<div class="chat-panel">
    @if (!IsPipelineConfigured())
    {
        <div class="pipeline-guidance" role="status">
            <p class="pipeline-guidance-title">@L["Chat.PipelineNotConfigured"]</p>
            <p class="pipeline-guidance-body">@L["Chat.PipelineInstructions"]</p>
            <button class="open-editor-btn" @onclick="OpenEditor">@L["Chat.OpenEditor"]</button>
        </div>
    }

    <div class="chat-messages" id="chat-messages">
        @if (Messages.Count == 0)
        {
            <div class="empty-state">
                <span class="empty-icon">💬</span>
                <p>@L["Chat.EmptyState"]</p>
            </div>
        }
        else
        {
            @foreach (var message in Messages)
            {
                <ChatMessage Role="@message.Role"
                             Content="@message.Content"
                             IsStreaming="@message.IsStreaming"
                             ToolCalls="@message.ToolCalls"
                             SedimentationSummary="@message.SedimentationSummary" />
            }
            @if (!_chatExecutionService.IsGenerating && Messages.Count > 0 && Messages.Last().Role == "assistant")
            {
                <button class="regenerate-btn" @onclick="RegenerateLastResponse">
                    <span>🔄</span> @L["Chat.Regenerate"]
                </button>
            }
        }
    </div>
    <TokenUsageDisplay
        InputTokens="@_contextManager.TotalInputTokens"
        OutputTokens="@_contextManager.TotalOutputTokens"
        CurrentContextTokens="@_contextManager.CurrentContextTokens"
        MaxContextTokens="@_contextManager.MaxContextTokens" />
    <div class="chat-input-wrapper">
        <ChatInput OnSend="SendMessage"
                   IsDisabled="@(_chatExecutionService.IsGenerating || IsContextLimitReached() || !IsPipelineConfigured())"
                   IsAgentRunning="@(_chatExecutionService.IsGenerating && _chatExecutionService.IsAgentMode)"
                   OnCancel="CancelGeneration" />
    </div>
</div>

@code {
    private int _lastRenderedMessageCount = -1;
    private string? _lastRenderedTailKey;
    private IReadOnlyList<ChatSessionMessage> Messages => _chatExecutionService.Messages;

    protected override async Task OnInitializedAsync()
    {
        _contextManager.OnStateChanged += HandleContextManagerChanged;
        _chatExecutionService.OnStateChanged += HandleChatExecutionStateChanged;
        LangSvc.LanguageChanged += OnLanguageChanged;
        _animaRuntimeManager.WiringConfigurationChanged += OnWiringConfigurationChanged;
        await _chatExecutionService.InitializeAsync();
    }

    private void OnWiringConfigurationChanged()
    {
        // Re-evaluate IsPipelineConfigured() after editor auto-save updates the WiringEngine.
        // Without this, ChatPanel would remain in "not configured" state even after a valid
        // pipeline is saved, because the render only happens when explicitly triggered.
        InvokeAsync(StateHasChanged);
    }

    private void HandleContextManagerChanged() => InvokeAsync(StateHasChanged);

    private void HandleChatExecutionStateChanged() => InvokeAsync(StateHasChanged);

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private void CancelGeneration() => _chatExecutionService.CancelGeneration();

    private bool IsContextLimitReached()
    {
        var utilization = _contextManager.GetContextUtilization();
        return _contextManager.GetContextStatus() == ContextStatus.Danger && utilization >= 90.0;
    }

    private bool IsPipelineConfigured()
    {
        var activeId = _animaContext.ActiveAnimaId;
        if (activeId == null) return false;
        var runtime = _animaRuntimeManager.GetRuntime(activeId);
        var currentConfig = runtime?.WiringEngine.GetCurrentConfiguration();
        return ChatPipelineConfigurationValidator.IsConfigured(currentConfig);
    }

    private async Task SendMessage(string userMessage)
    {
        if (string.IsNullOrWhiteSpace(userMessage) || _chatExecutionService.IsGenerating)
        {
            return;
        }

        if (!IsPipelineConfigured())
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        var result = await _chatExecutionService.SendMessageAsync(userMessage);
        if (result.Status == ChatCommandStatus.ContextLimitReached)
        {
            await JS.InvokeVoidAsync("chatHelpers.showContextLimitModal", result.CurrentTokens, result.MaxTokens);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RegenerateLastResponse()
    {
        if (_chatExecutionService.IsGenerating || !IsPipelineConfigured())
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await _chatExecutionService.RegenerateLastResponseAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var tailKey = BuildTailRenderKey();
        if (firstRender || _lastRenderedMessageCount != Messages.Count || _lastRenderedTailKey != tailKey)
        {
            _lastRenderedMessageCount = Messages.Count;
            _lastRenderedTailKey = tailKey;
            await ScrollToBottomIfNeededAsync();
        }
    }

    private async Task ScrollToBottomIfNeededAsync()
    {
        var shouldScroll = await JS.InvokeAsync<bool>("chatHelpers.shouldAutoScroll", "chat-messages");
        if (shouldScroll)
        {
            await JS.InvokeVoidAsync("chatHelpers.scrollToBottom", "chat-messages");
        }
    }

    private void OpenEditor()
    {
        _navigation.NavigateTo("/editor");
    }

    private string BuildTailRenderKey()
    {
        if (Messages.Count == 0)
        {
            return "";
        }

        var tail = Messages[^1];
        return string.Join("|",
            tail.Role,
            tail.IsStreaming,
            tail.Content.Length,
            tail.ToolCalls.Count,
            tail.SedimentationSummary?.Count ?? 0);
    }

    public ValueTask DisposeAsync()
    {
        _contextManager.OnStateChanged -= HandleContextManagerChanged;
        _chatExecutionService.OnStateChanged -= HandleChatExecutionStateChanged;
        LangSvc.LanguageChanged -= OnLanguageChanged;
        _animaRuntimeManager.WiringConfigurationChanged -= OnWiringConfigurationChanged;

        return ValueTask.CompletedTask;
    }
}
