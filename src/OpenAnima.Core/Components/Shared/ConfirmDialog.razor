@inject IStringLocalizer<SharedResources> L
@inject LanguageService LangSvc
@implements IDisposable

@if (IsVisible)
{
    <div class="modal-backdrop" @onclick="Cancel"></div>
    <div class="modal-dialog" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h2>@Title</h2>
        </div>
        <div class="modal-body">
            <p>@Message</p>
        </div>
        <div class="modal-actions">
            <button class="btn btn-secondary" @onclick="Cancel">@L["Common.Cancel"]</button>
            <button class="btn @ConfirmButtonClass" @onclick="Confirm">@ConfirmText</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string Message { get; set; } = "";

    [Parameter]
    public string ConfirmText { get; set; } = "Confirm";

    [Parameter]
    public string ConfirmButtonClass { get; set; } = "btn-danger";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    protected override void OnInitialized()
    {
        LangSvc.LanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync();
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }

    public void Dispose()
    {
        LangSvc.LanguageChanged -= OnLanguageChanged;
    }
}
