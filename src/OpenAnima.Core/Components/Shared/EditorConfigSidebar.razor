@using OpenAnima.Core.Services
@using OpenAnima.Core.Anima
@using OpenAnima.Core.Ports
@using OpenAnima.Core.Wiring
@using OpenAnima.Core.Routing
@using OpenAnima.Contracts
@using OpenAnima.Contracts.Ports
@implements IDisposable
@inject EditorStateService _editorState
@inject IModuleConfigStore _configService
@inject IModuleContext _animaContext
@inject IPortRegistry _portRegistry
@inject ICrossAnimaRouter _router
@inject IAnimaRuntimeManager _runtimeManager
@inject LanguageService LangSvc
@inject IStringLocalizer<SharedResources> L
@inject ModuleSchemaService _schemaService
@inject ILLMProviderRegistry _providerRegistry

<div class="editor-config-sidebar @(_editorState.SelectedNodeId != null ? "visible" : "")">
    @if (_selectedNode != null)
    {
        <div class="sidebar-header">
            <h3>@GetModuleDisplayName(_selectedNode.ModuleName)</h3>
            <div class="header-actions">
                <button class="action-btn text-error" @onclick="HandleDelete" title="@L["Editor.Config.Delete"]" aria-label="Delete Module">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                </button>
                <button class="action-btn" @onclick="HandleClose" title="Close" aria-label="Close Sidebar">
                    <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        </div>
        <div class="sidebar-content">
            <!-- Metadata Section -->
            <div class="info-section">
                <label>@L["Editor.Config.Version"]</label>
                <span>1.0.0</span>
            </div>
            <div class="info-section">
                <label>@L["Editor.Config.Description"]</label>
                <span>@GetModuleDescription(_selectedNode.ModuleName)</span>
            </div>

            <!-- Ports Section -->
            <div class="info-section">
                <label>@L["Editor.Config.Ports"]</label>
                @{
                    var ports = _portRegistry.GetPorts(_selectedNode.ModuleName);
                    var inputs = ports.Where(p => p.Direction == PortDirection.Input).ToList();
                    var outputs = ports.Where(p => p.Direction == PortDirection.Output).ToList();
                }
                @if (ports.Count == 0)
                {
                    <span class="text-muted">@L["Editor.Config.None"]</span>
                }
                else
                {
                    <div class="port-columns">
                        <div class="port-column">
                            <div class="port-column-header">@L["Editor.Config.Inputs"]</div>
                            @if (inputs.Count == 0)
                            {
                                <span class="text-muted">@L["Editor.Config.None"]</span>
                            }
                            else
                            {
                                @foreach (var port in inputs)
                                {
                                    <span class="port-item">@port.Name (@port.Type)</span>
                                }
                            }
                        </div>
                        <div class="port-column">
                            <div class="port-column-header">@L["Editor.Config.Outputs"]</div>
                            @if (outputs.Count == 0)
                            {
                                <span class="text-muted">@L["Editor.Config.None"]</span>
                            }
                            else
                            {
                                @foreach (var port in outputs)
                                {
                                    <span class="port-item">@port.Name (@port.Type)</span>
                                }
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Runtime Status Section -->
            <div class="info-section">
                <label>@L["Editor.Config.Status"]</label>
                @{
                    var runtimeState = _editorState.GetModuleState(_editorState.SelectedNodeId!);
                    var stateText = runtimeState?.State switch
                    {
                        "Running" => L["Editor.Config.Running"].Value,
                        "Error" => L["Editor.Config.Error"].Value,
                        _ => L["Editor.Config.Idle"].Value
                    };
                    var stateClass = runtimeState?.State switch
                    {
                        "Running" => "status-running",
                        "Error" => "status-error",
                        _ => "status-idle"
                    };
                }
                <div class="status-display">
                    <span class="status-dot @stateClass"></span>
                    <span>@stateText</span>
                </div>
                @if (runtimeState?.State == "Error" && runtimeState.ErrorMessage != null)
                {
                    <p class="error-message">@runtimeState.ErrorMessage</p>
                }
            </div>

            <!-- Configuration Form Section -->
            <div class="config-section">
                <label class="section-header">@L["Editor.Config.Title"]</label>
                @if (_currentConfig.Count == 0)
                {
                    <p class="text-muted">@L["Editor.Config.NoConfigFields"]</p>
                }
                else if (_selectedNode.ModuleName == "LLMModule" && _currentSchema != null)
                {
                    @* LLM Module: Custom cascading dropdown UI *@
                    var llmSlug = _currentConfig.GetValueOrDefault("llmProviderSlug", "");
                    var llmModelId = _currentConfig.GetValueOrDefault("llmModelId", "");
                    var allProviders = _providerRegistry.GetAllProviders();

                    <div class="config-form">
                        @* Provider Dropdown *@
                        <div class="config-field">
                            <label>@L["Editor.LLM.Provider"]</label>
                            <select value="@llmSlug"
                                    @onchange="HandleProviderChanged">
                                <option value="">@L["Editor.LLM.ProviderPlaceholder"]</option>
                                @foreach (var provider in allProviders)
                                {
                                    var modelCount = _providerRegistry.GetModels(provider.Slug).Count;
                                    var displayText = $"{provider.DisplayName} ({modelCount} models)";

                                    if (!provider.IsEnabled && provider.Slug != llmSlug)
                                    {
                                        @* Disabled provider not currently selected — greyed, not selectable *@
                                        <option value="@provider.Slug" disabled>@displayText (已禁用)</option>
                                    }
                                    else if (!provider.IsEnabled && provider.Slug == llmSlug)
                                    {
                                        @* Disabled provider IS the currently saved selection — show it as current value *@
                                        <option value="@provider.Slug">@displayText (已禁用)</option>
                                    }
                                    else
                                    {
                                        <option value="@provider.Slug">@displayText</option>
                                    }
                                }
                                <option disabled>──────────</option>
                                <option value="__manual__">@L["Editor.LLM.ManualOption"]</option>
                            </select>

                            @* Inline warning when saved provider is disabled *@
                            @if (!string.IsNullOrEmpty(llmSlug) && llmSlug != "__manual__")
                            {
                                var savedProvider = _providerRegistry.GetProvider(llmSlug);
                                if (savedProvider != null && !savedProvider.IsEnabled)
                                {
                                    <span class="warning-inline">@L["Editor.LLM.ProviderDisabledWarning"]</span>
                                }
                            }
                        </div>

                        @* Model Dropdown — visible only when a registered provider is selected *@
                        @if (!string.IsNullOrEmpty(llmSlug) && llmSlug != "__manual__")
                        {
                            var models = _providerRegistry.GetModels(llmSlug);
                            <div class="config-field">
                                <label>@L["Editor.LLM.Model"]</label>
                                <select value="@llmModelId"
                                        @onchange="@(e => HandleConfigChanged("llmModelId", e.Value?.ToString() ?? ""))">
                                    <option value="">@L["Editor.LLM.ModelPlaceholder"]</option>
                                    @foreach (var model in models)
                                    {
                                        var modelDisplay = string.IsNullOrEmpty(model.DisplayAlias)
                                            ? model.ModelId
                                            : $"{model.ModelId} ({model.DisplayAlias})";

                                        @* NOTE: No model-disabled rendering — LLMModelInfo has no IsEnabled field.
                                           All models from a provider are rendered as selectable. Model-level
                                           disable requires adding IsEnabled to LLMModelInfo (future phase). *@
                                        <option value="@model.ModelId">@modelDisplay</option>
                                    }
                                </select>

                                @* Incomplete config warning — provider selected but no model *@
                                @if (string.IsNullOrEmpty(llmModelId))
                                {
                                    <span class="warning-inline">@L["Editor.LLM.ModelNotSelectedWarning"]</span>
                                }
                            </div>
                        }

                        @* No providers registered hint *@
                        @if (allProviders.Count == 0 && string.IsNullOrEmpty(llmSlug))
                        {
                            <span class="field-hint">@L["Editor.LLM.NoProvidersRegistered"]</span>
                        }

                        @* Manual Configuration Fields — visible only when __manual__ selected *@
                        @if (llmSlug == "__manual__")
                        {
                            <span class="field-hint">@L["Editor.LLM.ManualHint"]</span>
                            <div class="config-field">
                                <label>@L["Editor.LLM.ApiUrl"]</label>
                                <input type="text"
                                       value="@_currentConfig.GetValueOrDefault("apiUrl", "")"
                                       @oninput="@(e => HandleConfigChanged("apiUrl", e.Value?.ToString() ?? ""))" />
                            </div>
                            <div class="config-field">
                                <label>@L["Editor.LLM.ApiKey"]</label>
                                <input type="password"
                                       value="@_currentConfig.GetValueOrDefault("apiKey", "")"
                                       @oninput="@(e => HandleConfigChanged("apiKey", e.Value?.ToString() ?? ""))" />
                            </div>
                            <div class="config-field">
                                <label>@L["Editor.LLM.ModelName"]</label>
                                <input type="text"
                                       value="@_currentConfig.GetValueOrDefault("modelName", "")"
                                       @oninput="@(e => HandleConfigChanged("modelName", e.Value?.ToString() ?? ""))" />
                            </div>
                        }
                    </div>
                }
                else if (_currentSchema != null)
                {
                    <div class="config-form">
                        @foreach (var field in _currentSchema.OrderBy(f => f.Order))
                        {
                            var fieldValue = _currentConfig.TryGetValue(field.Key, out var v) ? v : (field.DefaultValue ?? "");
                            <div class="config-field">
                                <label title="@field.Description">@field.DisplayName</label>
                                @switch (field.Type)
                                {
                                    case ConfigFieldType.Int:
                                    case ConfigFieldType.Number:
                                        <input type="number"
                                               value="@fieldValue"
                                               @oninput="@(e => HandleConfigChanged(field.Key, e.Value?.ToString() ?? string.Empty))" />
                                        break;
                                    case ConfigFieldType.Bool:
                                        <select value="@fieldValue"
                                                @onchange="@(e => HandleConfigChanged(field.Key, e.Value?.ToString() ?? "false"))">
                                            <option value="true" selected="@(fieldValue == "true")">True</option>
                                            <option value="false" selected="@(fieldValue != "true")">False</option>
                                        </select>
                                        break;
                                    case ConfigFieldType.Secret:
                                        <input type="password"
                                               value="@fieldValue"
                                               @oninput="@(e => HandleConfigChanged(field.Key, e.Value?.ToString() ?? string.Empty))" />
                                        break;
                                    case ConfigFieldType.MultilineText:
                                        <textarea rows="6"
                                                  @oninput="@(e => HandleConfigChanged(field.Key, e.Value?.ToString() ?? string.Empty))">@fieldValue</textarea>
                                        break;
                                    case ConfigFieldType.Enum:
                                    case ConfigFieldType.Dropdown:
                                        <select value="@fieldValue"
                                                @onchange="@(e => HandleConfigChanged(field.Key, e.Value?.ToString() ?? string.Empty))">
                                            @if (field.EnumValues != null)
                                            {
                                                @foreach (var opt in field.EnumValues)
                                                {
                                                    <option value="@opt" selected="@(opt == fieldValue)">@opt</option>
                                                }
                                            }
                                        </select>
                                        break;
                                    default:
                                        <input type="text"
                                               value="@fieldValue"
                                               @oninput="@(e => HandleConfigChanged(field.Key, e.Value?.ToString() ?? string.Empty))" />
                                        break;
                                }
                                @if (field.Description != null)
                                {
                                    <span class="field-hint">@field.Description</span>
                                }
                                @if (_validationErrors.ContainsKey(field.Key))
                                {
                                    <span class="field-error">@L["Editor.Config.ValidationError"]</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Fallback: render raw key-value pairs for modules without schema (existing behavior) -->
                    <div class="config-form">
                        @foreach (var kvp in _currentConfig)
                        {
                            <div class="config-field">
                                <label>@kvp.Key</label>
                                @if (kvp.Key == "targetAnimaId")
                                {
                                    <select value="@kvp.Value" @onchange="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))">
                                        <option value="">-- Select Anima --</option>
                                        @foreach (var anima in _runtimeManager.GetAll())
                                        {
                                            <option value="@anima.Id" selected="@(anima.Id == kvp.Value)">@anima.Name</option>
                                        }
                                    </select>
                                }
                                else if (kvp.Key == "targetPortName")
                                {
                                    var selectedAnimaId = _currentConfig.TryGetValue("targetAnimaId", out var aid) ? aid : "";
                                    var targetPorts = !string.IsNullOrEmpty(selectedAnimaId) ? _router.GetPortsForAnima(selectedAnimaId) : Array.Empty<PortRegistration>();
                                    <select value="@kvp.Value" @onchange="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))">
                                        <option value="">-- Select Port --</option>
                                        @foreach (var port in targetPorts)
                                        {
                                            <option value="@port.PortName" selected="@(port.PortName == kvp.Value)">@port.PortName — @port.Description</option>
                                        }
                                    </select>
                                }
                                else if (kvp.Key == "matchedService")
                                {
                                    var currentAnimaId = _animaContext.ActiveAnimaId ?? "";
                                    var ownPorts = !string.IsNullOrEmpty(currentAnimaId) ? _router.GetPortsForAnima(currentAnimaId) : Array.Empty<PortRegistration>();
                                    <select value="@kvp.Value" @onchange="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))">
                                        <option value="">-- Select Service --</option>
                                        @foreach (var port in ownPorts)
                                        {
                                            <option value="@port.PortName" selected="@(port.PortName == kvp.Value)">@port.PortName — @port.Description</option>
                                        }
                                    </select>
                                }
                                else if (kvp.Key == "template")
                                {
                                    <textarea rows="6"
                                              @oninput="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))">@kvp.Value</textarea>
                                }
                                else if (kvp.Key == "apiKey")
                                {
                                    <input type="password"
                                           value="@kvp.Value"
                                           @oninput="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))" />
                                }
                                else if (kvp.Key == "method")
                                {
                                    <select value="@kvp.Value"
                                            @onchange="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? "GET"))">
                                        @foreach (var m in new[] { "GET", "POST", "PUT", "DELETE", "PATCH" })
                                        {
                                            <option value="@m" selected="@(kvp.Value == m)">@m</option>
                                        }
                                    </select>
                                }
                                else if (kvp.Key == "headers")
                                {
                                    <textarea rows="4"
                                              @oninput="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))">@kvp.Value</textarea>
                                }
                                else if (kvp.Key == "body")
                                {
                                    <textarea rows="6"
                                              @oninput="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))">@kvp.Value</textarea>
                                }
                                else
                                {
                                    <input type="text"
                                           value="@kvp.Value"
                                           @oninput="@(e => HandleConfigChanged(kvp.Key, e.Value?.ToString() ?? string.Empty))" />
                                }
                                @if (_validationErrors.ContainsKey(kvp.Key))
                                {
                                    <span class="field-error">@L["Editor.Config.ValidationError"]</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Toast Notification -->
<div class="toast-notification @(_showToast ? "visible" : "")">
    @L["Editor.Config.SavedToast"]
</div>

@code {
    private ModuleNode? _selectedNode;
    private Dictionary<string, string> _currentConfig = new();
    private IReadOnlyList<ConfigFieldDescriptor>? _currentSchema;
    private Dictionary<string, string> _validationErrors = new();
    private string? _lastSelectedNodeId;
    private string? _lastAnimaId;
    private bool _showToast;
    private CancellationTokenSource? _autoSaveDebounce;

    protected override void OnInitialized()
    {
        _editorState.OnStateChanged += OnEditorStateChanged;
        _animaContext.ActiveAnimaChanged += OnAnimaChanged;
        LangSvc.LanguageChanged += OnLanguageChanged;

        LoadSelectedNode();
    }

    private void OnEditorStateChanged()
    {
        var currentNodeId = _editorState.SelectedNodeId;
        if (currentNodeId != _lastSelectedNodeId)
        {
            _lastSelectedNodeId = currentNodeId;
            LoadSelectedNode();
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnAnimaChanged()
    {
        var currentAnimaId = _animaContext.ActiveAnimaId;
        if (currentAnimaId != _lastAnimaId)
        {
            _lastAnimaId = currentAnimaId;
            LoadConfig();
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChanged() => InvokeAsync(() => { LangSvc.EnsureThreadCulture(); StateHasChanged(); });

    private void LoadSelectedNode()
    {
        var nodeId = _editorState.SelectedNodeId;
        if (nodeId == null)
        {
            _selectedNode = null;
            _currentConfig = new Dictionary<string, string>();
            _currentSchema = null;
            _validationErrors.Clear();
            return;
        }

        _selectedNode = _editorState.Configuration.Nodes
            .FirstOrDefault(n => n.ModuleId == nodeId);

        LoadConfig();
    }

    private void LoadConfig()
    {
        if (_selectedNode == null || _animaContext.ActiveAnimaId == null)
        {
            _currentConfig = new Dictionary<string, string>();
            _currentSchema = null;
            return;
        }

        _currentConfig = _configService.GetConfig(
            _animaContext.ActiveAnimaId,
            _selectedNode.ModuleName);

        // Discover schema fields and merge defaults for keys not yet persisted
        _currentSchema = _schemaService.GetSchema(_selectedNode.ModuleName);
        if (_currentSchema != null)
        {
            foreach (var field in _currentSchema)
            {
                if (!_currentConfig.ContainsKey(field.Key) && field.DefaultValue != null)
                {
                    _currentConfig[field.Key] = field.DefaultValue;
                }
            }
        }

        _validationErrors.Clear();
        _lastAnimaId = _animaContext.ActiveAnimaId;
    }

    private string GetModuleDisplayName(string moduleName)
    {
        var key = $"Module.DisplayName.{moduleName}";
        var localized = L[key];
        return localized.ResourceNotFound ? moduleName : localized.Value;
    }

    private string GetModuleDescription(string moduleName)
    {
        var key = $"Module.Description.{moduleName}";
        var localized = L[key];
        return localized.ResourceNotFound ? L["Editor.Config.NoDescription"].Value : localized.Value;
    }

    private void HandleConfigChanged(string key, string newValue)
    {
        _currentConfig[key] = newValue;

        // Allow empty values for "template", "body", "headers", and LLM selection keys
        // (llmProviderSlug and llmModelId are legitimately empty when unselected)
        if (key != "template" && key != "body" && key != "headers"
            && key != "llmProviderSlug" && key != "llmModelId"
            && string.IsNullOrWhiteSpace(newValue))
        {
            _validationErrors[key] = "empty";
        }
        else
        {
            _validationErrors.Remove(key);
        }

        // Trigger auto-save with debounce if no validation errors
        if (_validationErrors.Count == 0)
        {
            TriggerAutoSave();
        }
    }

    private void HandleProviderChanged(ChangeEventArgs e)
    {
        var newSlug = e.Value?.ToString() ?? "";
        HandleConfigChanged("llmProviderSlug", newSlug);

        // Clear model selection when provider changes (cascade reset)
        HandleConfigChanged("llmModelId", "");
    }

    private async void TriggerAutoSave()
    {
        _autoSaveDebounce?.Cancel();
        _autoSaveDebounce?.Dispose();
        _autoSaveDebounce = new CancellationTokenSource();

        try
        {
            await Task.Delay(500, _autoSaveDebounce.Token);

            if (_selectedNode != null && _animaContext.ActiveAnimaId != null)
            {
                await _configService.SetConfigAsync(
                    _animaContext.ActiveAnimaId,
                    _selectedNode.ModuleName,
                    new Dictionary<string, string>(_currentConfig));

                // Show toast
                _showToast = true;
                await InvokeAsync(StateHasChanged);

                await Task.Delay(2000, _autoSaveDebounce.Token);
                _showToast = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Debounce cancelled, ignore
        }
    }

    private void HandleDelete()
    {
        _editorState.DeleteSelected();
        // The state change will trigger re-render and auto-close the sidebar
    }

    private void HandleClose()
    {
        _editorState.ClearSelection();
    }

    public void Dispose()
    {
        _editorState.OnStateChanged -= OnEditorStateChanged;
        _animaContext.ActiveAnimaChanged -= OnAnimaChanged;
        LangSvc.LanguageChanged -= OnLanguageChanged;
        _autoSaveDebounce?.Cancel();
        _autoSaveDebounce?.Dispose();
    }
}
