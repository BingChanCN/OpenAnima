@using Markdig
@using Markdown.ColorCode
@using OpenAnima.Core.Services
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> L

@if (Role == "user")
{
    <div class="message user">
        <div class="message-content">
            @Content
            @if (IsStreaming)
            {
                <span class="typing-cursor">|</span>
            }
        </div>
        <button class="copy-btn" @onclick="CopyToClipboard" title="@L["Common.CopyToClipboard"]">
            @if (_copied)
            {
                <span class="copied-feedback">&#10003;</span>
            }
            else
            {
                <span>&#128203;</span>
            }
        </button>
    </div>
}
else
{
    <div class="message assistant">
        <span class="ai-icon">&#9670;</span>
        <div class="message-content">
            @if (ToolCalls.Count > 0)
            {
                <div class="tool-cards">
                    @foreach (var tool in ToolCalls)
                    {
                        <div class="@GetToolCardClasses(tool)">
                            <button class="tool-card-header"
                                    type="button"
                                    aria-expanded="@tool.IsExpanded"
                                    @onclick="() => tool.IsExpanded = !tool.IsExpanded">
                                <span class="tool-status-icon @GetStatusClass(tool.Status)">
                                    @GetStatusIcon(tool.Status)
                                </span>
                                @if (tool.Category == ToolCategory.Memory)
                                {
                                    <span class="memory-card-icon" aria-hidden="true">&#129504;</span>
                                    <span class="tool-name">@GetMemoryToolTitle(tool.ToolName)</span>
                                    @if (!string.IsNullOrWhiteSpace(tool.TargetUri))
                                    {
                                        <span class="tool-uri-pill" title="@tool.TargetUri">@tool.TargetUri</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(tool.FoldedSummary))
                                    {
                                        <span class="tool-summary">@tool.FoldedSummary</span>
                                    }
                                }
                                else
                                {
                                    <span class="tool-name">@tool.ToolName</span>
                                }
                                <span class="tool-expand-chevron">@(tool.IsExpanded ? "\u25B2" : "\u25BC")</span>
                            </button>
                            @if (tool.IsExpanded)
                            {
                                <div class="tool-card-body">
                                    @if (tool.Parameters.Count > 0)
                                    {
                                        <div class="tool-params">
                                            @foreach (var param in tool.Parameters)
                                            {
                                                <div class="tool-param-row">
                                                    <span class="param-key">@param.Key</span>
                                                    <span class="param-value">@param.Value</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(tool.ResultSummary))
                                    {
                                        <div class="tool-result">@tool.ResultSummary</div>
                                    }
                                    @if (tool.Status == ToolCallStatus.Success && IsMemoryDeleteTool(tool))
                                    {
                                        <div class="tool-delete-note">@L["Chat.MemoryDeleteRecoverable"]</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            @RenderContent()
            @if (IsStreaming)
            {
                <span class="typing-cursor">|</span>
            }
            @if (!IsStreaming && (ToolCalls.Count > 0 || SedimentationSummary?.Count > 0))
            {
                <div class="message-badges">
                    @if (SedimentationSummary?.Count > 0)
                    {
                        <div class="sedimentation-chip" aria-live="polite">
                            <span aria-hidden="true">&#129504;</span>
                            <span>@GetSedimentationChipText(SedimentationSummary.Count)</span>
                        </div>
                    }
                    @if (ToolCalls.Count > 0)
                    {
                        <div class="tool-badge">@string.Format(L["Chat.ToolCountBadge"], ToolCalls.Count)</div>
                    }
                </div>
            }
        </div>
        <button class="copy-btn" @onclick="CopyToClipboard" title="@L["Common.CopyToClipboard"]">
            @if (_copied)
            {
                <span class="copied-feedback">&#10003;</span>
            }
            else
            {
                <span>&#128203;</span>
            }
        </button>
    </div>
}

@code {
    private static readonly MarkdownPipeline _pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml() // XSS prevention
        .UseColorCode(HtmlFormatterType.Style)
        .Build();

    private bool _copied = false;

    [Parameter]
    public string Role { get; set; } = "";

    [Parameter]
    public string Content { get; set; } = "";

    [Parameter]
    public bool IsStreaming { get; set; }

    [Parameter]
    public List<ToolCallInfo> ToolCalls { get; set; } = new();

    [Parameter]
    public SedimentationSummaryInfo? SedimentationSummary { get; set; }

    private MarkupString RenderContent()
    {
        if (Role == "assistant")
        {
            var html = Markdig.Markdown.ToHtml(Content, _pipeline);
            return (MarkupString)html;
        }
        return (MarkupString)Content;
    }

    private static string GetStatusClass(ToolCallStatus status) => status switch
    {
        ToolCallStatus.Running => "tool-status-running",
        ToolCallStatus.Success => "tool-status-success",
        ToolCallStatus.Failed => "tool-status-failed",
        _ => ""
    };

    private static MarkupString GetStatusIcon(ToolCallStatus status) => status switch
    {
        ToolCallStatus.Running => (MarkupString)"<span class=\"spinner\"></span>",
        ToolCallStatus.Success => (MarkupString)"<span class=\"status-check\">\u2713</span>",
        ToolCallStatus.Failed => (MarkupString)"<span class=\"status-x\">\u2717</span>",
        _ => (MarkupString)""
    };

    private string GetMemoryToolTitle(string toolName) => toolName switch
    {
        "memory_create" => L["Chat.MemoryCreateTitle"].Value,
        "memory_update" => L["Chat.MemoryUpdateTitle"].Value,
        "memory_delete" => L["Chat.MemoryDeleteTitle"].Value,
        _ => toolName
    };

    private string GetSedimentationChipText(int count)
    {
        var template = count == 1
            ? L["Chat.SedimentationChipSingular"].Value
            : L["Chat.SedimentationChipPlural"].Value;
        return string.Format(template, count);
    }

    private static string GetToolCardClasses(ToolCallInfo tool)
    {
        var classes = "tool-card";
        if (tool.IsExpanded)
        {
            classes += " expanded";
        }

        if (tool.Category == ToolCategory.Memory)
        {
            classes += " tool-card-memory";
        }

        if (IsMemoryDeleteTool(tool))
        {
            classes += " tool-card-delete";
        }

        return classes;
    }

    private static bool IsMemoryDeleteTool(ToolCallInfo tool) =>
        tool.Category == ToolCategory.Memory &&
        string.Equals(tool.ToolName, "memory_delete", StringComparison.Ordinal);

    private async Task CopyToClipboard()
    {
        var success = await JS.InvokeAsync<bool>("chatHelpers.copyToClipboard", Content);
        if (success)
        {
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
    }
}
