@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> L
@inject LanguageService LanguageService
@inject IJSRuntime JS
@implements IDisposable

<div class="app-container">
    <aside class="sidebar @(SidebarCollapsed ? "collapsed" : "") @(MobileMenuOpen ? "mobile-open" : "")">
        <div class="sidebar-header">
            <div class="logo-area">
                <span class="logo-icon">&#x25C6;</span>
                @if (!SidebarCollapsed)
                {
                    <span class="logo-text">OpenAnima</span>
                }
            </div>
            @if (!SidebarCollapsed)
            {
                <ConnectionStatus />
            }
            <button class="sidebar-toggle"
                    @onclick="ToggleSidebar"
                    title="@(SidebarCollapsed ? "Expand" : "Collapse")"
                    aria-label="Toggle sidebar">
                @(SidebarCollapsed ? "\u25B6" : "\u25C0")
            </button>
        </div>
        <CascadingValue Value="SidebarCollapsed" Name="SidebarCollapsed">
            <div class="anima-list-section">
                <AnimaListPanel />
            </div>
        </CascadingValue>
        <nav class="sidebar-nav" role="navigation" aria-label="Main navigation">
            <NavLink href="/" class="nav-item" Match="NavLinkMatch.All">
                <span class="nav-icon">&#x25A3;</span>
                @if (!SidebarCollapsed)
                {
                    <span class="nav-label">@L["Nav.Dashboard"]</span>
                }
            </NavLink>
            <NavLink href="/modules" class="nav-item">
                <span class="nav-icon">&#x25A8;</span>
                @if (!SidebarCollapsed)
                {
                    <span class="nav-label">@L["Nav.Modules"]</span>
                }
            </NavLink>
            <NavLink href="/heartbeat" class="nav-item">
                <span class="nav-icon">&#x25C9;</span>
                @if (!SidebarCollapsed)
                {
                    <span class="nav-label">@L["Nav.Heartbeat"]</span>
                }
            </NavLink>
            <NavLink href="/monitor" class="nav-item">
                <span class="nav-icon">&#x25CE;</span>
                @if (!SidebarCollapsed)
                {
                    <span class="nav-label">@L["Nav.Monitor"]</span>
                }
            </NavLink>
            <NavLink href="/editor" class="nav-item">
                <span class="nav-icon">&#x25C8;</span>
                @if (!SidebarCollapsed)
                {
                    <span class="nav-label">@L["Nav.Editor"]</span>
                }
            </NavLink>
            <NavLink href="/settings" class="nav-item">
                <span class="nav-icon">&#x2699;</span>
                @if (!SidebarCollapsed)
                {
                    <span class="nav-label">@L["Nav.Settings"]</span>
                }
            </NavLink>
        </nav>
    </aside>

    @if (MobileMenuOpen)
    {
        <div class="sidebar-overlay" @onclick="ToggleMobileMenu"></div>
    }

    <main class="main-content" role="main">
        <button class="hamburger-btn" @onclick="ToggleMobileMenu" aria-label="Toggle menu">
            &#x2630;
        </button>
        @Body
    </main>
</div>

@code {
    private bool SidebarCollapsed { get; set; }
    private bool MobileMenuOpen { get; set; }

    protected override void OnInitialized()
    {
        LanguageService.LanguageChanged += OnLanguageChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "openanima-language");
            if (!string.IsNullOrEmpty(saved))
            {
                LanguageService.SetLanguage(saved);
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleSidebar()
    {
        SidebarCollapsed = !SidebarCollapsed;
    }

    private void ToggleMobileMenu()
    {
        MobileMenuOpen = !MobileMenuOpen;
    }

    public void Dispose()
    {
        LanguageService.LanguageChanged -= OnLanguageChanged;
    }
}
