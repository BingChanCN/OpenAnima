@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> L
@inject LanguageService LanguageService
@inject IJSRuntime JS
@implements IDisposable

<div class="app-container">
    <aside class="sidebar @(SidebarCollapsed ? "collapsed" : "") @(MobileMenuOpen ? "mobile-open" : "")">
        <div class="sidebar-header" @onclick="HandleSidebarHeaderClick" style="@(SidebarCollapsed ? "cursor: pointer;" : "")">
            <div class="logo-area">
                <span class="logo-icon">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                        <polyline points="2 17 12 22 22 17"></polyline>
                        <polyline points="2 12 12 17 22 12"></polyline>
                    </svg>
                </span>
                @if (!SidebarCollapsed)
                {
                    <span class="logo-text">OpenAnima</span>
                }
            </div>
            @if (!SidebarCollapsed)
            {
                <ConnectionStatus />
            }
            <button class="sidebar-toggle"
                    @onclick="ToggleSidebar"
                    @onclick:stopPropagation="true"
                    title="@(SidebarCollapsed ? L["MainLayout.ExpandSidebar"] : L["MainLayout.CollapseSidebar"])"
                    aria-label="@L["MainLayout.ToggleSidebar"]">
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    @if (SidebarCollapsed)
                    {
                        <polyline points="9 18 15 12 9 6"></polyline>
                    }
                    else
                    {
                        <polyline points="15 18 9 12 15 6"></polyline>
                    }
                </svg>
            </button>
        </div>
        <CascadingValue Value="SidebarCollapsed" Name="SidebarCollapsed">
            <div class="anima-list-section">
                <AnimaListPanel />
            </div>
        </CascadingValue>
        <nav class="sidebar-nav" role="navigation" aria-label="@L["MainLayout.MainNavigation"]">
            @if (!SidebarCollapsed)
            {
                <div class="nav-list-header">
                    <span class="nav-list-title">@L["MainLayout.Navigation"]</span>
                </div>
            }
            
            <div class="nav-cards">
                <NavLink href="/" class="nav-item" Match="NavLinkMatch.All">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Dashboard"]</span>
                    }
                </NavLink>
                <NavLink href="/modules" class="nav-item">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Modules"]</span>
                    }
                </NavLink>
                <NavLink href="/heartbeat" class="nav-item">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Heartbeat"]</span>
                    }
                </NavLink>
                <NavLink href="/monitor" class="nav-item">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Monitor"]</span>
                    }
                </NavLink>
                <NavLink href="/editor" class="nav-item">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><path d="M13 6h3a2 2 0 0 1 2 2v7"></path><line x1="6" y1="9" x2="6" y2="21"></line></svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Editor"]</span>
                    }
                </NavLink>
                <NavLink href="/runs" class="nav-item">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Runs"]</span>
                    }
                </NavLink>
                <NavLink href="/memory" class="nav-item">
                    <span class="nav-icon">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M8 1V5M8 11V15M1 8H5M11 8H15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Memory"]</span>
                    }
                </NavLink>
                <NavLink href="/settings" class="nav-item">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    </span>
                    @if (!SidebarCollapsed)
                    {
                        <span class="nav-label">@L["Nav.Settings"]</span>
                    }
                </NavLink>
            </div>
        </nav>
    </aside>

    @if (MobileMenuOpen)
    {
        <div class="sidebar-overlay" @onclick="ToggleMobileMenu"></div>
    }

    <main class="main-content" role="main">
        <button class="hamburger-btn" @onclick="ToggleMobileMenu" aria-label="@L["MainLayout.ToggleMenu"]">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
        <div @key="LanguageService.Current.Name">
            @Body
        </div>
    </main>
</div>

@code {
    private bool SidebarCollapsed { get; set; }
    private bool MobileMenuOpen { get; set; }

    protected override void OnInitialized()
    {
        LanguageService.LanguageChanged += OnLanguageChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "openanima-language");
            if (!string.IsNullOrEmpty(saved))
            {
                LanguageService.SetLanguage(saved);
                LanguageService.EnsureThreadCulture();
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                // Ensure thread culture matches default on first render
                LanguageService.EnsureThreadCulture();
            }
        }
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(() =>
        {
            LanguageService.EnsureThreadCulture();
            StateHasChanged();
        });
    }

    private void HandleSidebarHeaderClick()
    {
        // Allow expanding the sidebar by clicking anywhere on the header when collapsed
        if (SidebarCollapsed)
        {
            ToggleSidebar();
        }
    }

    private void ToggleSidebar()
    {
        SidebarCollapsed = !SidebarCollapsed;
    }

    private void ToggleMobileMenu()
    {
        MobileMenuOpen = !MobileMenuOpen;
    }

    public void Dispose()
    {
        LanguageService.LanguageChanged -= OnLanguageChanged;
    }
}
