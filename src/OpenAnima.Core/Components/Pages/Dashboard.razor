@page "/"
@using OpenAnima.Core.Services
@using OpenAnima.Core.Anima
@inject IModuleService ModuleService
@inject IAnimaRuntimeManager AnimaRuntimeManager
@inject IAnimaContext AnimaContext
@inject IStringLocalizer<SharedResources> L
@inject LanguageService LangSvc
@implements IDisposable

<div class="dashboard-container">
    <h1 class="page-title">@L["Dashboard.Title"]</h1>

    <div class="summary-grid">
        <div class="summary-card card">
            <span class="summary-icon">&#x25A8;</span>
            <div class="summary-content">
                <span class="summary-label">@L["Dashboard.ModuleCount"]</span>
                <span class="summary-value">@ModuleService.Count</span>
            </div>
        </div>

        <div class="summary-card card">
            <span class="summary-icon">&#x25C9;</span>
            <div class="summary-content">
                <span class="summary-label">@L["Dashboard.HeartbeatStatus"]</span>
                <span class="summary-value status-indicator @(ActiveRuntime?.IsRunning == true ? "running" : "stopped")">
                    @(ActiveRuntime?.IsRunning == true ? L["Heartbeat.Running"].Value : L["Heartbeat.Stopped"].Value)
                </span>
            </div>
        </div>

        <div class="summary-card card">
            <span class="summary-icon">&#x29D7;</span>
            <div class="summary-content">
                <span class="summary-label">@L["Heartbeat.TickCount"]</span>
                <span class="summary-value mono">@(ActiveRuntime?.HeartbeatLoop.TickCount ?? 0)</span>
            </div>
        </div>
    </div>

    <div class="chat-container">
        <ChatPanel />
    </div>
</div>

@code {
    private AnimaRuntime? ActiveRuntime =>
        AnimaContext.ActiveAnimaId != null
            ? AnimaRuntimeManager.GetRuntime(AnimaContext.ActiveAnimaId)
            : null;

    protected override void OnInitialized()
    {
        AnimaContext.ActiveAnimaChanged += OnActiveAnimaChanged;
        LangSvc.LanguageChanged += OnLanguageChanged;
    }

    private void OnActiveAnimaChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AnimaContext.ActiveAnimaChanged -= OnActiveAnimaChanged;
        LangSvc.LanguageChanged -= OnLanguageChanged;
    }
}
