@page "/runs/{RunId}"
@using OpenAnima.Core.Runs
@using OpenAnima.Core.RunPersistence
@using Microsoft.AspNetCore.SignalR.Client
@inject IRunService RunService
@inject IRunRepository Repository
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@implements IAsyncDisposable

@if (_notFound)
{
    <div class="empty-state">
        <h3>@L["RunDetail.NotFound.Heading"]</h3>
        <p>@L["RunDetail.NotFound.Body"]</p>
    </div>
}
else if (_run == null)
{
    <p>@L["RunDetail.Loading"]</p>
}
else
{
    <a href="/runs" class="back-link">@L["RunDetail.BackLink"]</a>
    <h1 class="page-title">@L["RunDetail.PageTitle"]</h1>

    <div class="run-overview">
        <div class="run-overview-header">
            <span class="run-id">@_run.RunId</span>
            <RunStateBadge State="@_run.CurrentState" />
        </div>
        <div class="run-objective">@_run.Objective</div>
        <div class="run-meta">
            <span>@_run.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
            <span class="run-workspace">@_run.WorkspaceRoot</span>
        </div>
        @if (_run.MaxSteps.HasValue || _run.MaxWallSeconds.HasValue)
        {
            <div class="run-budgets">
                @if (_run.MaxSteps.HasValue)
                {
                    <BudgetIndicator Current="@_steps.Count" Max="@_run.MaxSteps" Label="@L["RunDetail.BudgetSteps"]" />
                }
                @if (_run.MaxWallSeconds.HasValue)
                {
                    <BudgetIndicator Current="@_wallSecondsElapsed" Max="@_run.MaxWallSeconds" Label="@L["RunDetail.BudgetSeconds"]" />
                }
            </div>
        }
        @{
            var stopReason = _stateEvents.LastOrDefault(e =>
                e.State is "Paused" or "Cancelled" or "Failed" or "Interrupted")?.Reason;
        }
        @if (!string.IsNullOrEmpty(stopReason))
        {
            <StopReasonBanner Reason="@stopReason" />
        }
    </div>

    <h2 class="section-title">@L["RunDetail.TimelineHeading"]</h2>

    <TimelineFilterBar ModuleNames="_moduleNames"
                       Statuses="_statuses"
                       ChainIds="_chainIds"
                       SelectedModule="_filterModule"
                       SelectedStatus="_filterStatus"
                       SelectedChain="_filterChain"
                       HasActiveFilters="_hasActiveFilters"
                       OnModuleFilterChanged="HandleModuleFilter"
                       OnStatusFilterChanged="HandleStatusFilter"
                       OnChainFilterChanged="HandleChainFilter"
                       OnClearFilters="HandleClearFilters" />

    @if (_steps.Count >= 100)
    {
        <div class="long-timeline-banner">@L["RunDetail.LongTimelineBanner", _steps.Count]</div>
    }

    @if (_filteredTimeline.Count == 0 && _timeline.Count > 0)
    {
        <div class="empty-state">
            <h3>@L["RunDetail.EmptyFilter.Heading"]</h3>
            <p>@L["RunDetail.EmptyFilter.Body"]</p>
        </div>
    }
    else if (_timeline.Count == 0)
    {
        <div class="empty-state">
            <h3>@L["RunDetail.EmptyTimeline.Heading"]</h3>
            <p>@L["RunDetail.EmptyTimeline.Body"]</p>
        </div>
    }
    else
    {
        <div class="timeline-list" role="list">
            @foreach (var entry in _filteredTimeline)
            {
                @if (entry.IsStateEvent && entry.StateEvent != null)
                {
                    var stateEvent = entry.StateEvent;
                    <StateEventRow Event="@stateEvent" />
                }
                else if (!entry.IsStateEvent && entry.Step != null)
                {
                    var step = entry.Step;
                    var isDimmed = _activeChainId != null && step.PropagationId != _activeChainId;
                    <StepTimelineRow Step="@step"
                                     IsExpanded="@(_expandedStepId == step.StepId)"
                                     IsHighlighted="@(_activeChainId != null && step.PropagationId == _activeChainId)"
                                     IsDimmed="isDimmed"
                                     ChainStepCount="@(_steps.Count(s => s.PropagationId == step.PropagationId))"
                                     OnToggle="@(() => ToggleStep(step.StepId))"
                                     OnChainClick="@(() => HandleChainClick(step.PropagationId))"
                                     OnChainFilterShortcut="@(() => HandleChainFilterShortcut(step.PropagationId))" />
                }
            }
        </div>
    }
}

@code {
    [Parameter]
    public string RunId { get; set; } = string.Empty;

    private RunDescriptor? _run;
    private List<StepRecord> _steps = new();
    private List<RunStateEvent> _stateEvents = new();
    private List<TimelineEntry> _timeline = new();
    private bool _notFound;
    private HubConnection? _hubConnection;
    private string? _expandedStepId;
    private string? _activeChainId;
    private int _wallSecondsElapsed = 0;

    private string? _filterModule;
    private string? _filterStatus;
    private string? _filterChain;

    private IReadOnlyList<string> _moduleNames => _steps.Select(s => s.ModuleName).Distinct().OrderBy(n => n).ToList();
    private IReadOnlyList<string> _statuses => _steps.Select(s => s.Status).Distinct().OrderBy(s => s).ToList();
    private IReadOnlyList<string> _chainIds => _steps.Where(s => !string.IsNullOrEmpty(s.PropagationId)).Select(s => s.PropagationId).Distinct().OrderBy(c => c).ToList();
    private bool _hasActiveFilters => _filterModule != null || _filterStatus != null || _filterChain != null;

    private List<TimelineEntry> _filteredTimeline => _timeline.Where(e =>
    {
        if (e.IsStateEvent) return _filterModule == null && _filterStatus == null && _filterChain == null;
        var step = e.Step!;
        if (_filterModule != null && step.ModuleName != _filterModule) return false;
        if (_filterStatus != null && step.Status != _filterStatus) return false;
        if (_filterChain != null && step.PropagationId != _filterChain) return false;
        return true;
    }).ToList();

    private record TimelineEntry(string OccurredAt, bool IsStateEvent, StepRecord? Step, RunStateEvent? StateEvent);

    private void RebuildTimeline()
    {
        var entries = new List<TimelineEntry>();
        foreach (var s in _steps)
            entries.Add(new TimelineEntry(s.OccurredAt, false, s, null));
        foreach (var e in _stateEvents)
            entries.Add(new TimelineEntry(e.OccurredAt, true, null, e));
        _timeline = entries.OrderBy(e => e.OccurredAt).ThenBy(e => e.IsStateEvent ? 0 : 1).ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        _run = await RunService.GetRunByIdAsync(RunId);
        if (_run == null) { _notFound = true; return; }

        _steps = (await Repository.GetStepsByRunIdAsync(RunId)).ToList();
        _stateEvents = (await Repository.GetStateEventsByRunIdAsync(RunId)).ToList();
        RebuildTimeline();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/runtime"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string, string, string, string, string, int?>("ReceiveStepCompleted",
            async (animaId, runId, stepId, moduleName, status, durationMs) =>
            {
                if (runId != RunId) return;
                var updatedSteps = await Repository.GetStepsByRunIdAsync(RunId);
                _steps = updatedSteps.ToList();
                RebuildTimeline();
                await InvokeAsync(StateHasChanged);
            });

        _hubConnection.On<string, string, string, string?>("ReceiveRunStateChanged",
            async (animaId, runId, state, reason) =>
            {
                if (runId != RunId) return;
                var parsed = Enum.Parse<RunState>(state);
                _run = _run! with { CurrentState = parsed };
                var updatedEvents = await Repository.GetStateEventsByRunIdAsync(RunId);
                _stateEvents = updatedEvents.ToList();
                RebuildTimeline();
                await InvokeAsync(StateHasChanged);
            });

        await _hubConnection.StartAsync();
    }

    private void ToggleStep(string stepId)
    {
        _expandedStepId = _expandedStepId == stepId ? null : stepId;
    }

    private void HandleChainClick(string? propagationId)
    {
        if (string.IsNullOrEmpty(propagationId)) return;
        _activeChainId = _activeChainId == propagationId ? null : propagationId;
    }

    private void HandleModuleFilter(string? value) { _filterModule = value; }
    private void HandleStatusFilter(string? value) { _filterStatus = value; }
    private void HandleChainFilter(string? value) { _filterChain = value; _activeChainId = null; }
    private void HandleClearFilters() { _filterModule = null; _filterStatus = null; _filterChain = null; _activeChainId = null; }
    private void HandleChainFilterShortcut(string? propagationId)
    {
        if (string.IsNullOrEmpty(propagationId)) return;
        _filterChain = propagationId;
        _activeChainId = null;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null) await _hubConnection.DisposeAsync();
    }
}
