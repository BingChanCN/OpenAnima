@page "/heartbeat"
@using Microsoft.AspNetCore.SignalR.Client
@using OpenAnima.Core.Anima
@inject IAnimaRuntimeManager AnimaRuntimeManager
@inject IAnimaContext AnimaContext
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@inject LanguageService LangSvc
@implements IAsyncDisposable

<h1 class="page-title">@L["Heartbeat.Title"]</h1>

<div class="heartbeat-container">
    <div class="status-card-large">
        <div class="status-label">@L["Dashboard.RuntimeStatus"]</div>
        <div class="status-value @(isRunning ? "running" : "stopped")">
            @(isRunning ? L["Heartbeat.Running"].Value : L["Heartbeat.Stopped"].Value)
        </div>

        <div class="control-section">
            <button class="btn @(isRunning ? "btn-danger" : "btn-primary") @(isLoading ? "loading" : "")"
                    disabled="@isLoading"
                    @onclick="ToggleHeartbeat">
                @if (isLoading) { <span class="spinner"></span> }
                @(isRunning ? L["Heartbeat.StopHeartbeat"].Value : L["Heartbeat.StartHeartbeat"].Value)
            </button>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }
        </div>
    </div>

    <div class="stats-container">
        <div class="stat-card card">
            <span class="stat-label">@L["Heartbeat.TickCount"]</span>
            <span class="stat-value mono">@tickCount</span>
        </div>
        <div class="stat-card card">
            <span class="stat-label">@L["Heartbeat.Latency"]</span>
            <span class="stat-value mono">@latencyMs.ToString("F2") ms</span>
        </div>
    </div>
</div>

<ConfirmDialog IsVisible="@showStopConfirm"
               Title="@L["Heartbeat.StopHeartbeat"]"
               Message="@L["Heartbeat.StopConfirm"]"
               ConfirmText="@L["Anima.Stop"]"
               ConfirmButtonClass="btn-danger"
               OnConfirm="@ConfirmStop"
               OnCancel="@CancelStop" />

@code {
    private HubConnection? hubConnection;
    private bool isLoading = false;
    private string? errorMessage = null;
    private bool isRunning;
    private long tickCount;
    private double latencyMs;
    private bool showStopConfirm = false;

    protected override async Task OnInitializedAsync()
    {
        AnimaContext.ActiveAnimaChanged += OnActiveAnimaChanged;
        LangSvc.LanguageChanged += OnLanguageChanged;

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/runtime"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, bool>("ReceiveHeartbeatStateChanged", (animaId, running) =>
        {
            if (animaId != AnimaContext.ActiveAnimaId) return;
            isRunning = running;
            errorMessage = null;
            InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, long, double>("ReceiveHeartbeatTick", (animaId, tick, latency) =>
        {
            if (animaId != AnimaContext.ActiveAnimaId) return;
            tickCount = tick;
            latencyMs = latency;
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        RefreshFromActiveRuntime();
    }

    private void OnActiveAnimaChanged()
    {
        RefreshFromActiveRuntime();
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private void RefreshFromActiveRuntime()
    {
        var activeId = AnimaContext.ActiveAnimaId;
        if (activeId == null) return;
        var runtime = AnimaRuntimeManager.GetRuntime(activeId);
        if (runtime != null)
        {
            isRunning = runtime.IsRunning;
            tickCount = runtime.HeartbeatLoop.TickCount;
            latencyMs = runtime.HeartbeatLoop.LastTickLatencyMs;
        }
        else
        {
            isRunning = false;
            tickCount = 0;
            latencyMs = 0;
        }
    }

    private async Task ToggleHeartbeat()
    {
        if (isRunning)
        {
            showStopConfirm = true;
            return;
        }

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var activeId = AnimaContext.ActiveAnimaId;
            if (activeId == null)
            {
                errorMessage = "No active Anima selected.";
                return;
            }
            var runtime = AnimaRuntimeManager.GetOrCreateRuntime(activeId);
            await runtime.HeartbeatLoop.StartAsync();
            isRunning = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to start: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmStop()
    {
        showStopConfirm = false;
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var activeId = AnimaContext.ActiveAnimaId;
            if (activeId == null)
            {
                errorMessage = "No active Anima selected.";
                return;
            }
            var runtime = AnimaRuntimeManager.GetRuntime(activeId);
            if (runtime != null)
                await runtime.HeartbeatLoop.StopAsync();
            isRunning = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to stop: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void CancelStop()
    {
        showStopConfirm = false;
    }

    public async ValueTask DisposeAsync()
    {
        AnimaContext.ActiveAnimaChanged -= OnActiveAnimaChanged;
        LangSvc.LanguageChanged -= OnLanguageChanged;
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }
}
