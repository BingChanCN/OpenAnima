@page "/modules"
@using OpenAnima.Core.Services
@using OpenAnima.Core.Plugins
@using OpenAnima.Contracts.Ports
@using OpenAnima.Core.Ports
@using OpenAnima.Core.Anima
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Forms
@inject IModuleService ModuleService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@inject LanguageService LangSvc
@inject IJSRuntime JS
@inject IAnimaModuleStateService ModuleStateService
@inject IModuleContext AnimaContext
@implements IAsyncDisposable

<div class="page-header">
    <h1 class="page-title">@L["Modules.Title"]</h1>
    <button class="btn btn-primary" @onclick="TriggerInstall">@L["Modules.Install"]</button>
</div>

<!-- Hidden InputFile for .oamod upload -->
<InputFile @ref="inputFileRef"
           OnChange="HandleFileSelected"
           accept=".oamod"
           style="display: none;"
           id="oamod-file-input" />

<!-- Search box -->
@if (ModuleService.Count > 0)
{
    <div class="search-box">
        <input type="text"
               class="search-input"
               placeholder="@L["Modules.Search"]"
               @bind="searchFilter"
               @bind:event="oninput" />
    </div>
}

<!-- Loading indicator during installation -->
@if (isInstalling)
{
    <div class="installing-banner">
        <span class="spinner"></span>
        <span>@L["Modules.Installing"]</span>
    </div>
}

<!-- Module cards grid -->
@if (ModuleService.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">📦</div>
        <p class="empty-state-text">@L["Modules.EmptyState"]</p>
        <button class="btn btn-primary" @onclick="TriggerInstall">@L["Modules.Install"]</button>
    </div>
}
else
{
    <div class="module-grid">
        @foreach (var entry in FilteredModules)
        {
            var moduleName = entry.Manifest.Name;
            <div class="module-card card"
                 @onclick="() => ShowSidebar(entry)"
                 @oncontextmenu="(e) => OpenContextMenu(e, entry)"
                 @oncontextmenu:preventDefault="true">
                <div class="module-card-header">
                    <span class="module-card-name">@entry.Module.Metadata.Name</span>
                    @{
                        var isEnabled = AnimaContext.ActiveAnimaId != null
                            && ModuleStateService.IsModuleEnabled(AnimaContext.ActiveAnimaId, entry.Manifest.Name);
                    }
                    <span class="status-badge @(isEnabled ? "enabled" : "disabled")">
                        @(isEnabled ? L["Modules.Enabled"] : L["Modules.Disabled"])
                    </span>
                </div>
                <div class="module-card-body">
                    <span class="module-version">v@(entry.Module.Metadata.Version)</span>
                </div>
                <div class="module-card-actions" @onclick:stopPropagation="true">
                    <button class="btn btn-sm btn-danger"
                            disabled="@isOperating"
                            @onclick="() => UninstallModule(moduleName)">
                        @L["Modules.Uninstall"]
                    </button>
                </div>
            </div>
        }
    </div>
}

<!-- Error display -->
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error-banner">
        @errorMessage
    </div>
}

<!-- Confirmation Dialog -->
<ConfirmDialog IsVisible="@showUninstallConfirm"
               Title="@L["Modules.Uninstall"]"
               Message="@L["Modules.UninstallConfirm"]"
               ConfirmText="@L["Modules.Uninstall"]"
               ConfirmButtonClass="btn-danger"
               OnConfirm="@ConfirmUninstall"
               OnCancel="@CancelUninstall" />

<!-- Module Detail Modal -->
<ModuleDetailModal IsVisible="@showModal"
                   Title="@(selectedModule?.Module.Metadata.Name ?? "")"
                   OnClose="@CloseModal">
    @if (selectedModule != null)
    {
        <div class="detail-grid">
            <div class="detail-row">
                <span class="detail-label">@L["Modules.Detail.Version"]</span>
                <span class="detail-value">@selectedModule.Module.Metadata.Version</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">@L["Modules.Detail.Description"]</span>
                <span class="detail-value">@(selectedModule.Module.Metadata.Description ?? L["Modules.Detail.NoDescription"].Value)</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">@L["Modules.Detail.LoadedAt"]</span>
                <span class="detail-value mono">@selectedModule.LoadedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">@L["Modules.Detail.Assembly"]</span>
                <span class="detail-value mono">@selectedModule.Manifest.EntryAssembly</span>
            </div>
        </div>

        <div class="port-section">
            <h3 class="section-subtitle">@L["Modules.Detail.Ports"]</h3>
            @{
                var ports = GetModulePorts(selectedModule);
                var inputs = ports.Where(p => p.Direction == PortDirection.Input).ToList();
                var outputs = ports.Where(p => p.Direction == PortDirection.Output).ToList();
            }
            @if (ports.Count == 0)
            {
                <p class="text-muted">@L["Modules.Detail.NoPorts"]</p>
            }
            else
            {
                <div class="port-columns">
                    <div class="port-column">
                        <div class="port-column-header">@L["Modules.Detail.Inputs"]</div>
                        @if (inputs.Count == 0)
                        {
                            <span class="text-muted">@L["Modules.Detail.None"]</span>
                        }
                        else
                        {
                            @foreach (var port in inputs)
                            {
                                <PortIndicator Port="@port" />
                            }
                        }
                    </div>
                    <div class="port-column">
                        <div class="port-column-header">@L["Modules.Detail.Outputs"]</div>
                        @if (outputs.Count == 0)
                        {
                            <span class="text-muted">@L["Modules.Detail.None"]</span>
                        }
                        else
                        {
                            @foreach (var port in outputs)
                            {
                                <PortIndicator Port="@port" />
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</ModuleDetailModal>

<ModuleContextMenu IsVisible="_showContextMenu"
                  X="_contextMenuX"
                  Y="_contextMenuY"
                  ModuleName="@(_contextModuleName ?? "")"
                  IsEnabled="_contextModuleEnabled"
                  OnEnable="HandleEnable"
                  OnDisable="HandleDisable"
                  OnUninstall="async () => { if (_contextModuleName != null) await UninstallModule(_contextModuleName); }"
                  OnViewDetails="HandleViewDetailsFromMenu"
                  OnClose="() => _showContextMenu = false" />

<ModuleDetailSidebar IsVisible="_showSidebar"
                     SelectedModule="_sidebarModule"
                     OnClose="CloseSidebar"
                     OnEnableDisable="HandleSidebarEnableDisable"
                     OnUninstall="async () => { if (_sidebarModule?.Manifest.Name != null) await UninstallModule(_sidebarModule.Manifest.Name); }" />

@code {
    private HubConnection? hubConnection;
    private InputFile? inputFileRef;
    private bool isInstalling = false;
    private bool isOperating = false;
    private string searchFilter = "";
    private string? errorMessage = null;
    private PluginRegistryEntry? selectedModule;
    private bool showModal;
    private bool showUninstallConfirm = false;
    private string? moduleToUninstall = null;

    // Context menu state
    private bool _showContextMenu;
    private double _contextMenuX, _contextMenuY;
    private string? _contextModuleName;
    private bool _contextModuleEnabled;

    // Sidebar state
    private bool _showSidebar;
    private PluginRegistryEntry? _sidebarModule;

    private IEnumerable<PluginRegistryEntry> FilteredModules =>
        ModuleService.GetAllModules()
            .Where(m => string.IsNullOrWhiteSpace(searchFilter) ||
                       m.Manifest.Name.Contains(searchFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        LangSvc.LanguageChanged += OnLanguageChanged;
        AnimaContext.ActiveAnimaChanged += HandleActiveAnimaChanged;

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/runtime"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, int>("ReceiveModuleCountChanged", async (animaId, count) =>
        {
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private async Task TriggerInstall()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('oamod-file-input').click()");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        isInstalling = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            // Read file data (max 50MB)
            const long maxFileSize = 50 * 1024 * 1024;
            using var stream = file.OpenReadStream(maxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var fileData = memoryStream.ToArray();

            // Call RuntimeHub.InstallModule
            var result = await hubConnection!.InvokeAsync<ModuleOperationResult>("InstallModule", file.Name, fileData);

            if (result.Success)
            {
                errorMessage = null;
            }
            else
            {
                errorMessage = $"{L["Modules.InstallFailed"]}: {result.Error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"{L["Modules.InstallFailed"]}: {ex.Message}";
        }
        finally
        {
            isInstalling = false;
            StateHasChanged();
        }
    }

    private async Task UninstallModule(string name)
    {
        moduleToUninstall = name;
        showUninstallConfirm = true;
    }

    private async Task ConfirmUninstall()
    {
        showUninstallConfirm = false;
        if (moduleToUninstall == null) return;

        var name = moduleToUninstall;
        moduleToUninstall = null;

        isOperating = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await hubConnection!.InvokeAsync<ModuleOperationResult>("UninstallModule", name);
            if (!result.Success)
            {
                errorMessage = $"Uninstall failed: {result.Error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Connection error: {ex.Message}";
        }
        finally
        {
            isOperating = false;
            StateHasChanged();
        }
    }

    private void CancelUninstall()
    {
        showUninstallConfirm = false;
        moduleToUninstall = null;
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private void ShowDetails(PluginRegistryEntry entry)
    {
        selectedModule = entry;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private List<PortMetadata> GetModulePorts(PluginRegistryEntry entry)
    {
        var discovery = new PortDiscovery();
        return discovery.DiscoverPorts(entry.Module.GetType());
    }

    private void OpenContextMenu(MouseEventArgs e, PluginRegistryEntry module)
    {
        _contextModuleName = module.Manifest.Name;
        _contextModuleEnabled = AnimaContext.ActiveAnimaId != null
            && ModuleStateService.IsModuleEnabled(AnimaContext.ActiveAnimaId, module.Manifest.Name);
        _contextMenuX = e.ClientX;
        _contextMenuY = e.ClientY;
        _showContextMenu = true;
    }

    private async Task HandleEnable()
    {
        _showContextMenu = false;
        if (AnimaContext.ActiveAnimaId == null || _contextModuleName == null) return;
        await ModuleStateService.SetModuleEnabled(AnimaContext.ActiveAnimaId, _contextModuleName, true);
        StateHasChanged();
    }

    private async Task HandleDisable()
    {
        _showContextMenu = false;
        if (AnimaContext.ActiveAnimaId == null || _contextModuleName == null) return;
        await ModuleStateService.SetModuleEnabled(AnimaContext.ActiveAnimaId, _contextModuleName, false);
        StateHasChanged();
    }

    private void HandleViewDetailsFromMenu()
    {
        _showContextMenu = false;
        var module = ModuleService.GetAllModules().FirstOrDefault(m => m.Manifest.Name == _contextModuleName);
        if (module != null)
        {
            _sidebarModule = module;
            _showSidebar = true;
        }
    }

    private void ShowSidebar(PluginRegistryEntry module)
    {
        _sidebarModule = module;
        _showSidebar = true;
    }

    private void CloseSidebar()
    {
        _showSidebar = false;
    }

    private async Task HandleSidebarEnableDisable()
    {
        if (AnimaContext.ActiveAnimaId == null || _sidebarModule == null) return;
        var isEnabled = ModuleStateService.IsModuleEnabled(AnimaContext.ActiveAnimaId, _sidebarModule.Manifest.Name);
        await ModuleStateService.SetModuleEnabled(AnimaContext.ActiveAnimaId, _sidebarModule.Manifest.Name, !isEnabled);
        StateHasChanged();
    }

    private void HandleActiveAnimaChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        LangSvc.LanguageChanged -= OnLanguageChanged;
        AnimaContext.ActiveAnimaChanged -= HandleActiveAnimaChanged;
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }
}
