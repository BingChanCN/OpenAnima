@page "/runs"
@using OpenAnima.Core.Runs
@using OpenAnima.Core.Anima
@using OpenAnima.Core.Wiring
@using OpenAnima.Core.Workflows
@inject IRunService RunService
@inject IModuleContext AnimaContext
@inject IAnimaRuntimeManager RuntimeManager
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@inject WorkflowPresetService PresetService
@implements IAsyncDisposable

<h1 class="page-title">@L["Runs.Title"]</h1>

<RunLaunchPanel OnStartRun="HandleStartRun" Presets="@_presets" />

@if (_startError != null)
{
    <span class="error-inline">@_startError</span>
}

<h2 class="section-title">@L["Runs.History"]</h2>

@if (_runs.Count == 0)
{
    <div class="empty-state">
        <h3>@L["Runs.EmptyHeading"]</h3>
        <p>@L["Runs.EmptyBody"]</p>
    </div>
}
else
{
    @foreach (var run in _runs)
    {
        <RunCard Run="@run"
                 StopReason="@(_stopReasons.GetValueOrDefault(run.RunId))"
                 StepCount="@(_stepCounts.GetValueOrDefault(run.RunId))"
                 OnPause="HandlePauseRun"
                 OnResume="HandleResumeRun"
                 OnCancel="HandleCancelRequest" />
    }
}

<ConfirmDialog IsVisible="@_showCancelConfirm"
               Title="@L["Runs.CancelConfirmTitle"]"
               Message="@L["Runs.CancelConfirmMessage"]"
               ConfirmText="@L["Runs.CancelConfirmAction"]"
               ConfirmButtonClass="btn-danger"
               OnConfirm="HandleCancelConfirm"
               OnCancel="HandleCancelDismiss" />

@code {
    private List<RunDescriptor> _runs = new();
    private Dictionary<string, string?> _stopReasons = new();
    private Dictionary<string, int> _stepCounts = new();
    private HubConnection? _hubConnection;
    private bool _showCancelConfirm;
    private string? _cancelTargetRunId;
    private string? _startError;
    private IReadOnlyList<WorkflowPresetInfo> _presets = [];

    protected override async Task OnInitializedAsync()
    {
        _presets = PresetService.ListPresets();
        _runs = (await RunService.GetAllRunsAsync()).ToList();

        foreach (var run in _runs)
        {
            _stepCounts[run.RunId] = 0;
        }

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/runtime"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string, string, string, string?>("ReceiveRunStateChanged",
            async (animaId, runId, state, reason) =>
            {
                var idx = _runs.FindIndex(r => r.RunId == runId);
                if (idx >= 0)
                {
                    var parsed = Enum.Parse<RunState>(state);
                    _runs[idx] = _runs[idx] with { CurrentState = parsed };
                    if (reason != null)
                        _stopReasons[runId] = reason;
                }
                else
                {
                    var updated = await RunService.GetAllRunsAsync();
                    _runs = updated.ToList();
                }
                await InvokeAsync(StateHasChanged);
            });

        _hubConnection.On<string, string, string, string, string, int?>("ReceiveStepCompleted",
            async (animaId, runId, stepId, moduleName, status, durationMs) =>
            {
                _stepCounts[runId] = _stepCounts.GetValueOrDefault(runId) + 1;
                await InvokeAsync(StateHasChanged);
            });

        await _hubConnection.StartAsync();
    }

    private async Task HandleStartRun((string objective, string workspace, int? maxSteps, int? maxWallSeconds, string? workflowPreset) args)
    {
        _startError = null;
        var animaId = AnimaContext.ActiveAnimaId;
        if (string.IsNullOrWhiteSpace(animaId))
        {
            _startError = L["Runs.NoActiveAnima"];
            return;
        }

        // Load preset wiring config into the engine before starting the run
        if (!string.IsNullOrEmpty(args.workflowPreset))
        {
            var config = await PresetService.LoadPresetAsync(args.workflowPreset);
            if (config != null)
            {
                var runtime = RuntimeManager.GetRuntime(animaId);
                runtime?.WiringEngine.LoadConfiguration(config);
            }
        }

        var result = await RunService.StartRunAsync(animaId, args.objective, args.workspace, args.maxSteps, args.maxWallSeconds, args.workflowPreset);
        if (result.IsSuccess)
        {
            _runs = (await RunService.GetAllRunsAsync()).ToList();
        }
        else
        {
            _startError = result.Message ?? L["Runs.StartFailed"];
            throw new InvalidOperationException(_startError);
        }
    }

    private async Task HandlePauseRun(string runId)
    {
        await RunService.PauseRunAsync(runId, "User paused");
        _runs = (await RunService.GetAllRunsAsync()).ToList();
    }

    private async Task HandleResumeRun(string runId)
    {
        await RunService.ResumeRunAsync(runId);
        _runs = (await RunService.GetAllRunsAsync()).ToList();
    }

    private void HandleCancelRequest(string runId)
    {
        _cancelTargetRunId = runId;
        _showCancelConfirm = true;
    }

    private async Task HandleCancelConfirm()
    {
        if (_cancelTargetRunId != null)
        {
            await RunService.CancelRunAsync(_cancelTargetRunId);
        }
        _showCancelConfirm = false;
        _cancelTargetRunId = null;
        _runs = (await RunService.GetAllRunsAsync()).ToList();
    }

    private void HandleCancelDismiss()
    {
        _showCancelConfirm = false;
        _cancelTargetRunId = null;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
